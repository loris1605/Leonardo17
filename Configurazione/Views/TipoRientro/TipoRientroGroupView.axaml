<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lc="using:Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="using:ControlStyles"
             xmlns:vm="using:Configurazione.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             KeyboardNavigation.TabNavigation="Cycle"
             Background="Transparent"
             x:DataType="vm:TipoRientroGroupViewModel"
             x:CompileBindings="True"
             x:Class="Configurazione.Views.TipoRientroGroupView">

    <Grid x:Name="MainGrid">
    
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="150"/>
        </Grid.ColumnDefinitions>    
    
        <lc:CrudToolBar x:Name="CrudBar"
                        GroupText="TIPO RIENTRO"
                        Grid.ColumnSpan="2"
                        FilterCommandVisibile="False"
                        AddCommand="{Binding AddCommand}"
                        DelCommand="{Binding DelCommand}"
                        UpdCommand="{Binding UpdCommand}"
                        CancelFilterCommand="{Binding FilterCommand}"/>

        <HeaderedContentControl BorderBrush="Black" 
                                Grid.Row="1" 
                                HorizontalAlignment="Stretch" 
                                VerticalAlignment="Stretch"
                                Name="Group"
                                BorderThickness="1"
                                CornerRadius="5"
                                Margin="3"
                                Background="Transparent">
        
            <HeaderedContentControl.Header>
                <TextBlock Text=" Tipi Rientro " 
                           Foreground="Black" 
                           Margin="3"
                           HorizontalAlignment="Center"/>
            </HeaderedContentControl.Header>

            <DataGrid ItemsSource="{Binding DataSource}"
                      Classes="Group"
                      x:Name="TipoRientroDataGrid"
                      SelectedItem="{Binding GroupBindingT}"
                      SelectedIndex="{Binding IdIndex}">
    
                <DataGrid.Columns >
                    
                    <DataGridTextColumn Header="Cod." 
                                        Binding="{Binding Id}" 
                                        IsVisible="False" />

                    <DataGridTextColumn Header="Nome" 
                                        Binding="{Binding Nome}" 
                                        Width="Auto" />
                                               
                    <DataGridTextColumn Header="Durata Ore" 
                                        Binding="{Binding DurataOre}" 
                                        Width="Auto" />

                    
                </DataGrid.Columns>
            
            </DataGrid>

        
        </HeaderedContentControl>

        <StackPanel Grid.Column="1" Orientation="Vertical" Grid.Row="1">

            
        
            <ui:UiButton x:Name="OperatoriButton"
                                 Margin="20,5"
                                 MinHeight="50"
                                 ToolTipText="GRUPPO OPERATORI"
                                 HorizontalAlignment="Stretch"
                                 Content=" OPERATORI"
                                 HorizontalContentAlignment="Center"
                                 Command="{Binding OperatoriCommand}"/>

            <ui:UiButton x:Name="PostazioniButton"
                                 Margin="20,5"
                                 MinHeight="50"
                                 ToolTipText="GRUPPO POSTAZIONI"
                                 HorizontalAlignment="Stretch"
                                 Content=" POSTAZIONI "
                                 Command="{Binding PostazioniCommand}"/>

            <ui:UiButton x:Name="SettoriButton"
                                 Margin="20,5"
                                 MinHeight="50"
                                 ToolTipText="GRUPPO SETTORI"
                                 HorizontalAlignment="Stretch"
                                 Content="SETTORI"
                                 HorizontalContentAlignment="Center"
                                 Command="{Binding SettoriCommand}"/>

            <ui:UiButton x:Name="RientriButton"
                                 Margin="20,5"
                                 MinHeight="50"
                                 ToolTipText="GRUPPO TARIFFE"
                                 HorizontalAlignment="Stretch"
                                 Content="TARIFFE"
                                 HorizontalContentAlignment="Center"
                                 Command="{Binding TariffeCommand}"/>
        
        </StackPanel>
    
    </Grid>
  
</UserControl>
