<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lc="using:Views"
             xmlns:map="using:Configurazione.ViewModels.Map"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="using:ControlStyles"
             xmlns:vm="using:Configurazione.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             KeyboardNavigation.TabNavigation="Cycle"
             Background="Transparent"
             x:DataType="vm:PermessiViewModel"
             x:Class="Configurazione.Views.PermessiView">

    <Grid x:Name="MainGrid" >
    
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="4*"/> <!-- PopupBorder -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="4*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ui:PopupBorder VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Grid.Row="1"
                        Grid.Column="1">
        
            <Grid x:Name="PopupGrid" >
            
                <Grid.RowDefinitions>
					<RowDefinition Height="50"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ui:UiTitolo x:Name="lblTitolo" 
                         FontSize="22" 
                         SubTitolo="True"
                         Margin="30,0"
                         HorizontalAlignment="Center"/>

                <Viewbox Grid.Row="1"
                         Margin="10"
                         Stretch="Uniform" StretchDirection="Both">
               

                    <HeaderedContentControl BorderBrush="Black" 
                                            HorizontalAlignment="Stretch" 
                                            VerticalAlignment="Stretch"
                                            Name="Group"
                                            Grid.Row="1"
                                            BorderThickness="1"
                                            CornerRadius="5"
                                            Margin="5"
                                            Background="Transparent">
                    
                        <HeaderedContentControl.Header>
                            <TextBlock Text=" POSTAZIONI " 
                                       Foreground="Black" 
                                       Margin="3"
                                       HorizontalAlignment="Center"/>
                        </HeaderedContentControl.Header>
                        
                        <DataGrid ItemsSource="{Binding DataSource}"
                                  SelectedItem="{Binding Path=BindingT}"
                                  MaxHeight="400"
                                  VerticalScrollBarVisibility="Auto"
                                  CanUserResizeColumns="True"
                                  IsReadOnly="False"
                                  Classes="Group">
    						
                            <DataGrid.Columns >
                            
                                <DataGridTextColumn Header="Cod." 
                                            x:DataType="map:ConfigurazionePostazioneElencoMap"
                                            Binding="{Binding Id}" 
                                            IsVisible="False" />
    
                                <DataGridTextColumn Header="Nome" 
                                            x:DataType="map:ConfigurazionePostazioneElencoMap"
                                            Binding="{Binding NomePostazione}" 
                                            IsReadOnly="True"
                                            Width="Auto" />
    
                                <DataGridTextColumn Header="Tipo" 
                                            x:DataType="map:ConfigurazionePostazioneElencoMap"
                                            Binding="{Binding NomeTipoPostazione}" 
                                            IsReadOnly="True"
                                            Width="Auto" />

                                <DataGridTemplateColumn Header="Permesso" IsReadOnly="False">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <!-- Usiamo il Binding con TwoWay per aggiornare subito il ViewModel -->
                                            <CheckBox IsChecked="{Binding HasPermesso, 
                                                      Mode=TwoWay,
                                                      UpdateSourceTrigger=PropertyChanged}" 
                                                      HorizontalAlignment="Center" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
    
                                <!--<DataGridCheckBoxColumn 
                                            Header="Permesso"
                                            x:DataType="vm:BindableObjects.PostazioneElencoMap"
                                            Binding="{Binding HasPermesso, 
                                                     Mode=TwoWay,
                                                     UpdateSourceTrigger=PropertyChanged}" 
                                            IsReadOnly="False"
                                            Width="Auto" />-->
                            
                            </DataGrid.Columns>
                            
                        </DataGrid>
                        
                    </HeaderedContentControl>
    
                </Viewbox>

                <TextBlock x:Name="InfoLabel"
                           Grid.Row="2"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="20,10">

                    <TextBlock.Styles>
                        <Style Selector="TextBlock">
                            <Style.Animations>
                                <Animation Duration="0:0:1" 
                                           IterationCount="Infinite" 
                                           PlaybackDirection="Alternate">
                                    <KeyFrame KeyTime="0:0:0">
                                        <Setter Property="Opacity" Value="1.0"/>
                                    </KeyFrame>
                                    <KeyFrame KeyTime="0:0:1">
                                        <Setter Property="Opacity" Value="0.3"/>
                                    </KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </TextBlock.Styles>

                </TextBlock>

                <lc:InputSaveBox x:Name="InputSaveBox"
                                 Grid.Row="3"
                                 Margin="20"
                                 SaveCommand="{Binding SaveCommand}"
                                 ExitCommand="{Binding EscPressedCommand}"/>
            
            </Grid>
        
            
        
        </ui:PopupBorder>
    
    </Grid>
 
</UserControl>
