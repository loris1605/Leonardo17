<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lc="using:Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="using:ControlStyles"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             KeyboardNavigation.TabNavigation="Cycle"
             Background="Transparent"
             x:CompileBindings="False"
             x:Class="Soci.Views.TesseraInputView">

    <Grid x:Name="MainGrid" >
    
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*"/> <!-- PopupBorder -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ui:PopupBorder VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Grid.Row="1"
                    Grid.Column="1">
        
            <Grid x:Name="PopupGrid">
            
                <Grid.RowDefinitions>
					<RowDefinition Height="50"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ui:UiTitolo x:Name="lblTitolo" 
                         FontSize="22" 
                         SubTitolo="True"
                         Margin="30,0" 
                         HorizontalAlignment="Center"/>

                <ui:UiTitolo x:Name="lblTitolo1" 
                         FontSize="22" 
                         Grid.Row="1"
                         SubTitolo="True"
                         Margin="30,0" 
                         HorizontalAlignment="Center"/>

                <Grid x:Name="InputGrid" 
                      Grid.Row="2"
                      Margin="10">
                
                    <Grid.RowDefinitions>
                        <RowDefinition Height="5"/>
						<RowDefinition Height="Auto" MinHeight="35"/>
                        <RowDefinition Height="Auto" MinHeight="35"/>
                        <RowDefinition Height="Auto" MinHeight="35"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <ui:UiLabelForGrid Text="NUMERO TESSERA :" 
                                       x:Name="NumeroTesseraLabel"
                                       Margin="10,10,0,10"
                                       Grid.Row="1"/>

                    <ui:UiIntegerTextBox Grid.Row="1" 
                                         x:Name="NumeroTesseraBox"
                                         Grid.Column="1"
                                         Margin="25,2,25,2"
                                         VerticalAlignment="Center"/>
                
                </Grid>

                <TextBlock x:Name="InfoLabel"
                           Grid.Row="3"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="20,10">

                    <TextBlock.Styles>
                        <Style Selector="TextBlock">
                            <Style.Animations>
                                <Animation Duration="0:0:1" 
                                           IterationCount="Infinite" 
                                           PlaybackDirection="Alternate">
                                    <KeyFrame KeyTime="0:0:0">
                                        <Setter Property="Opacity" Value="1.0"/>
                                    </KeyFrame>
                                    <KeyFrame KeyTime="0:0:1">
                                        <Setter Property="Opacity" Value="0.3"/>
                                    </KeyFrame>
                                </Animation>
                            </Style.Animations>
                        </Style>
                    </TextBlock.Styles>

                </TextBlock>

                <lc:InputSaveBox x:Name="InputSaveBox"
                                 Grid.Row="3"
                                 Margin="20"
                                 SaveCommand="{Binding SaveCommand}"
                                 ExitCommand="{Binding EscPressedCommand}"/>

            </Grid>
        
        </ui:PopupBorder>
    
    </Grid>
  
</UserControl>
