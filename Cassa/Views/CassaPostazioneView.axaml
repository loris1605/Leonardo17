<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lc="using:Views"
             xmlns:vm="using:Cassa.ViewModels"
             mc:Ignorable="d"
             d:DesignWidth="800"
             d:DesignHeight="450"
             KeyboardNavigation.TabNavigation="Cycle"
             Background="LightSteelBlue"
             x:DataType="vm:CassaPostazioneViewModel"
             x:Class="Cassa.Views.CassaPostazioneView">

    <Grid x:Name="MainGrid">
    
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- TITOLO -->
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>  

        <lc:TitleView Grid.Row="0"
                      TitoloPagina="POSTAZIONE CASSA"
                      x:Name="Title"
                      ButtonText="Esci"
                      ToolTipText="TORNA A MENU PRINCIPALE"
                      ExitCommand="{Binding EscPressedCommand}"/>
    
    </Grid>


</UserControl>
